[application]

config/name="Delaney"
config/version="0"
run/main_scene="uid://caf0nnifxcu0a"
run/enable_alt_space_menu=true
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cyqit6r38p3q3"

[autoload]

AppConfig="*uid://cjke6crjg14a0"
