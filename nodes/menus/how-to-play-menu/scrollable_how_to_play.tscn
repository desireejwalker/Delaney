[node name="Label19" type="Label" parent="ScrollContainer/VBoxContainer" unique_id=598863928]
layout_mode = 2
theme_override_fonts/font = ExtResource("1_rmpmu")
theme_override_font_sizes/font_size = 36
text = "(Instead of waiting for the right time, you can aim with W, A, S, and D, and after a second, I'll launch with my current Flow State. BLUNT included.)"
horizontal_alignment = 1
autowrap_mode = 3

[node name="Label20" type="Label" parent="ScrollContainer/VBoxContainer" unique_id=1795550124]
