[node name="Label15" type="Label" parent="ScrollContainer/VBoxContainer" unique_id=733892626]
layout_mode = 2
theme_override_fonts/font = ExtResource("1_rmpmu")
theme_override_font_sizes/font_size = 36
text = "(The longer you let me spin with my hammer, the higher your combo, and more variety in my tricks, the higher of a flow state I'll reach.)"
horizontal_alignment = 1
autowrap_mode = 3

[node name="Label16" type="Label" parent="ScrollContainer/VBoxContainer" unique_id=858411484]
layout_mode = 2
theme_override_fonts/font = ExtResource("1_rmpmu")
theme_override_font_sizes/font_size = 36
text = "(Flow States affect your score multiplier, the damage my hammer does, and the speed and distance that a Hammer Launch will launch me at.)"
horizontal_alignment = 1
autowrap_mode = 3

